{
  "name": "kopi-wealth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "migrate:preview": "ts-node src/migrate.ts --stage preview",
    "migrate:prod": "ts-node src/migrate.ts --stage prod",
    "migrate:check:preview": "ts-node src/migrate.ts --stage preview --check",
    "migrate:check:prod": "ts-node src/migrate.ts --stage prod --check"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/client-secrets-manager": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.1.3",
    "aws-sdk-client-mock": "^4.1.0",
    "serverless": "^3.40.0",
    "serverless-domain-manager": "^7.3.7",
    "serverless-esbuild": "^1.54.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^3.1.3"
  }
}
